<!--
  package= and the legacy <uses-sdk> are gone in AGP 8 — namespace, minSdk
  and targetSdk all come from build.gradle. versionCode/versionName are still
  declared in build.gradle as well.

  Every <activity>/<service> with an intent filter must explicitly set
  android:exported on API 31+, so each component below carries one.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Storage perms are capped at API 32 because the IME does not actually
         touch shared storage; on API 33+ these permissions are scoped/no-ops
         and Play Console flags them as misuse if they appear unconditionally. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <!-- The IME service. android:exported must be true so the system can
             bind to it; the BIND_INPUT_METHOD permission gates who's allowed
             to actually bind. -->
        <service
            android:name=".MainNovaKeyService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>

            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method"
                android:theme="@style/AppTheme" />
        </service>

        <activity
            android:name=".setup.SetupActivity"
            android:exported="false"
            android:icon="@drawable/ic_launcher"
            android:label="@string/app_name" />

        <!-- Launcher entry point — must be exported on API 31+. -->
        <activity
            android:name=".settings.SettingsActivity"
            android:exported="true"
            android:icon="@drawable/ic_launcher"
            android:label="@string/app_name"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.intent.action.CREATE_SHORTCUT" />
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".tutorial.TutorialActivity"
            android:configChanges="orientation|keyboardHidden"
            android:exported="false"
            android:icon="@drawable/ic_launcher"
            android:label="@string/app_name"
            android:theme="@style/TutorialTheme"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".settings.StylePreferenceActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:label="@string/title_style_preference" />

        <activity
            android:name=".EmojiSettingActivity"
            android:exported="false"
            android:hardwareAccelerated="false" />

    </application>

</manifest>
