<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <hyperobject.keyboard.novakey.widgets.NovaKeyPreview
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:id="@+id/preview" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/preview">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <hyperobject.keyboard.novakey.widgets.ObservableHorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <hyperobject.keyboard.novakey.widgets.pickers.ThemePicker
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/themePicker" />
                </hyperobject.keyboard.novakey.widgets.ObservableHorizontalScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp">

                    <CheckBox
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/cb_auto_color"
                        android:id="@+id/autoColor" />

                    <CheckBox
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/cb_three_dee"
                        android:id="@+id/threeDee" />
                </LinearLayout>

                <hyperobject.keyboard.novakey.widgets.ObservableHorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <hyperobject.keyboard.novakey.widgets.pickers.ColorPicker
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/primaryColor" />
                </hyperobject.keyboard.novakey.widgets.ObservableHorizontalScrollView>

                <hyperobject.keyboard.novakey.widgets.ObservableHorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <hyperobject.keyboard.novakey.widgets.pickers.ColorPicker
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/secondaryColor" />
                </hyperobject.keyboard.novakey.widgets.ObservableHorizontalScrollView>

                <hyperobject.keyboard.novakey.widgets.ObservableHorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <hyperobject.keyboard.novakey.widgets.pickers.ColorPicker
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/ternaryColor" />
                </hyperobject.keyboard.novakey.widgets.ObservableHorizontalScrollView>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="110dp" />
            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="@drawable/drop_shadow"
            android:layout_below="@id/preview" />
    </RelativeLayout>

    <hyperobject.keyboard.novakey.widgets.pickers.ReleasePicker
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:id="@+id/releasePick" />

</RelativeLayout>